+    private fun applyGradationLine(sx: Float, sy: Float, ex: Float, ey: Float) {
+        val selected = selectedLayer as? TextLayer ?: return
+        var angleRad = Math.atan2((ey - sy).toDouble(), (ex - sx).toDouble())
+        var angleDeg = Math.toDegrees(angleRad).toFloat()
+        if (angleDeg < 0) angleDeg += 360f
+
+        for (layer in layers) {
+            if (layer !is TextLayer || !layer.isVisible) continue
+            val m = Matrix()
+            m.postTranslate(-layer.x, -layer.y)
+            m.postRotate(-layer.rotation)
+            m.postScale(1f / layer.scaleX, 1f / layer.scaleY)
+
+            val pts = floatArrayOf(sx, sy, ex, ey)
+            m.mapPoints(pts)
+            val lsx = pts[0]
+            val lsy = pts[1]
+            val lex = pts[2]
+            val ley = pts[3]
+
+            val w = layer.getWidth() / 2f
+            val h = layer.getHeight() / 2f
+
+            if (lineIntersectsRect(lsx, lsy, lex, ley, -w, -h, w, h)) {
+                layer.isGradient = selected.isGradient
+                layer.isGradientText = selected.isGradientText
+                layer.isGradientStroke = selected.isGradientStroke
+                layer.isGradientShadow = selected.isGradientShadow
+                layer.gradientStartColor = selected.gradientStartColor
+                layer.gradientEndColor = selected.gradientEndColor
+                var localAngle = (angleDeg - layer.rotation) % 360f
+                if (localAngle < 0) localAngle += 360f
+                layer.gradientAngle = localAngle.toInt()
+            }
+        }
+        onGradationApplied?.invoke()
+    }
+
+    private fun lineIntersectsRect(x1: Float, y1: Float, x2: Float, y2: Float, rx1: Float, ry1: Float, rx2: Float, ry2: Float): Boolean {
+        val minX = minOf(x1, x2)
+        val maxX = maxOf(x1, x2)
+        val minY = minOf(y1, y2)
+        val maxY = maxOf(y1, y2)
+        if (maxX < rx1 || minX > rx2 || maxY < ry1 || minY > ry2) return false
+        if (x1 >= rx1 && x1 <= rx2 && y1 >= ry1 && y1 <= ry2) return true
+        if (x2 >= rx1 && x2 <= rx2 && y2 >= ry1 && y2 <= ry2) return true
+        return linesIntersect(x1, y1, x2, y2, rx1, ry1, rx2, ry1) || linesIntersect(x1, y1, x2, y2, rx1, ry2, rx2, ry2) || linesIntersect(x1, y1, x2, y2, rx1, ry1, rx1, ry2) || linesIntersect(x1, y1, x2, y2, rx2, ry1, rx2, ry2)
+    }
+
+    private fun linesIntersect(x1: Float, y1: Float, x2: Float, y2: Float, x3: Float, y3: Float, x4: Float, y4: Float): Boolean {
+        val den = (y4 - y3) * (x2 - x1) - (x4 - x3) * (y2 - y1)
+        if (den == 0f) return false
+        val ua = ((x4 - x3) * (y1 - y3) - (y4 - y3) * (x1 - x3)) / den
+        val ub = ((x2 - x1) * (y1 - y3) - (y2 - y1) * (x1 - x3)) / den
+        return ua >= 0f && ua <= 1f && ub >= 0f && ub <= 1f
+    }
